# Configuracoes locais e credenciais
.env
.env.*
!.env.example

# Sessoes, logs e arquivos temporarios da aplicacao
storage/sessions/*
storage/logs/*
tmp/*
output/*
!storage/sessions/.gitkeep
!storage/logs/.gitkeep
!tmp/.gitkeep

# Uploads feitos pelos usuarios
public/uploads/*
!public/uploads/.htaccess
!public/uploads/.gitkeep

# Dumps, backups e pacotes locais
*.sql.gz
*.dump
*.bak
*.backup
*.zip
*.rar
*.7z

# Arquivos temporarios do sistema e do editor
__pycache__/
*.pyc
Thumbs.db
Desktop.ini
*.tmp
*.temp
*.log
